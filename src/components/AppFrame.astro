---
/**
 * A polished app-window frame for product screenshots / mockups.
 * Renders macOS-style traffic lights and an optional title-bar label.
 */
interface Props {
  label?: string;
  class?: string;
  glow?: boolean;
}
const { label = 'API Circle', class: className = '', glow = true } = Astro.props;
---
<div
  class:list={[
    'overflow-hidden rounded-2xl border border-edge bg-panel shadow-panel',
    glow && 'shadow-glow',
    className,
  ]}
>
  <div class="flex items-center gap-2 border-b border-edge bg-surface/70 px-4 py-2.5">
    <span class="flex gap-1.5" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-node-red/80"></span>
      <span class="h-3 w-3 rounded-full bg-node-amber/80"></span>
      <span class="h-3 w-3 rounded-full bg-node-green/80"></span>
    </span>
    {label && <span class="ml-2 truncate text-xs font-medium text-fg-dim">{label}</span>}
  </div>
  <div class="relative">
    <slot />
  </div>
</div>

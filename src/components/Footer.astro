---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { FOOTER_NAV } from '../data/nav.ts';
import { SITE } from '../data/site.ts';
const year = new Date().getFullYear();
---
<footer class="border-t border-edge bg-panel/40">
  <div class="container-page py-16">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-6">
      <div class="col-span-2">
        <Logo />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-fg-muted">
          An API workspace you can <code class="rounded bg-surface px-1 py-0.5 text-[0.8em] text-brand">git diff</code> — and an AI can drive.
        </p>
        <p class="mt-4 inline-flex items-center gap-2 text-xs font-medium text-fg-dim">
          <svg viewBox="0 0 36 24" class="h-3 w-[18px] shrink-0 rounded-[2px] ring-1 ring-inset ring-black/20" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flag of India">
            <rect width="36" height="24" fill="#fff" />
            <rect width="36" height="8" fill="#ff9933" />
            <rect y="16" width="36" height="8" fill="#138808" />
            <g transform="translate(18 12)" fill="none" stroke="#000080" stroke-width="0.35">
              <circle r="3" stroke-width="0.5" />
              <circle r="0.7" fill="#000080" stroke="none" />
              <line y1="-3" y2="3" />
              <line y1="-3" y2="3" transform="rotate(15)" />
              <line y1="-3" y2="3" transform="rotate(30)" />
              <line y1="-3" y2="3" transform="rotate(45)" />
              <line y1="-3" y2="3" transform="rotate(60)" />
              <line y1="-3" y2="3" transform="rotate(75)" />
              <line y1="-3" y2="3" transform="rotate(90)" />
              <line y1="-3" y2="3" transform="rotate(105)" />
              <line y1="-3" y2="3" transform="rotate(120)" />
              <line y1="-3" y2="3" transform="rotate(135)" />
              <line y1="-3" y2="3" transform="rotate(150)" />
              <line y1="-3" y2="3" transform="rotate(165)" />
            </g>
          </svg>
          {SITE.origin}
        </p>
      </div>

      {
        FOOTER_NAV.map((group) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-fg-dim">{group.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener' : undefined}
                    class="inline-flex items-center gap-1 text-sm text-fg-muted transition-colors hover:text-brand"
                  >
                    {item.label}
                    {item.external && <Icon name="arrow-up-right" size={12} class="opacity-60" />}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-edge pt-8 sm:flex-row sm:items-center">
      <p class="text-sm text-fg-dim">
        © {year} API Circle · Source-available ·
        <a href={SITE.links.license} target="_blank" rel="noopener" class="hover:text-brand">License</a>
      </p>
      <div class="flex items-center gap-3">
        <a href={SITE.links.github} target="_blank" rel="noopener" class="text-fg-dim transition-colors hover:text-brand" aria-label="GitHub">
          <Icon name="github" size={20} />
        </a>
        <a href={SITE.appUrl} target="_blank" rel="noopener" class="text-fg-dim transition-colors hover:text-brand" aria-label="Open the web app">
          <Icon name="globe" size={20} />
        </a>
      </div>
    </div>
  </div>
</footer>

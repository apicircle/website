---
import Icon from './Icon.astro';
import AppFrame from './AppFrame.astro';
import Screenshot from './Screenshot.astro';

interface Props {
  eyebrow?: string;
  eyebrowIcon?: string;
  title: string;
  body: string;
  points?: string[];
  screenshot: string;
  screenshotAlt: string;
  frameLabel?: string;
  reverse?: boolean;
  accent?: 'brand' | 'green' | 'blue' | 'amber' | 'red' | 'sky';
  ctaHref?: string;
  ctaLabel?: string;
}
const {
  eyebrow,
  eyebrowIcon,
  title,
  body,
  points = [],
  screenshot,
  screenshotAlt,
  frameLabel,
  reverse = false,
  accent = 'brand',
  ctaHref,
  ctaLabel,
} = Astro.props;

const TEXT: Record<string, string> = {
  brand: 'text-brand',
  green: 'text-node-green',
  blue: 'text-node-blue',
  amber: 'text-node-amber',
  red: 'text-node-red',
  sky: 'text-node-sky',
};
const accentText = TEXT[accent] ?? TEXT.brand;
---
<div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
  <div class:list={[reverse && 'lg:order-2']}>
    {
      eyebrow && (
        <span class:list={['eyebrow', accentText]}>
          {eyebrowIcon && <Icon name={eyebrowIcon} size={14} />}
          {eyebrow}
        </span>
      )
    }
    <h2 class="mt-4 text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl">{title}</h2>
    <p class="mt-4 text-pretty text-lg leading-relaxed text-fg-muted">{body}</p>
    {
      points.length > 0 && (
        <ul class="mt-6 space-y-3">
          {points.map((p) => (
            <li class="flex items-start gap-3">
              <span class:list={['mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-surface', accentText]}>
                <Icon name="check" size={13} strokeWidth={2.5} />
              </span>
              <span class="text-[15px] leading-relaxed text-fg-muted" set:html={p} />
            </li>
          ))}
        </ul>
      )
    }
    {
      ctaHref && (
        <a href={ctaHref} class:list={['mt-7 inline-flex items-center gap-1.5 text-sm font-semibold', accentText]}>
          {ctaLabel ?? 'Learn more'}
          <Icon name="arrow-right" size={15} />
        </a>
      )
    }
  </div>

  <div class:list={[reverse && 'lg:order-1']}>
    <AppFrame label={frameLabel} glow={false} class="hover:shadow-glow">
      <Screenshot name={screenshot} alt={screenshotAlt} />
    </AppFrame>
  </div>
</div>

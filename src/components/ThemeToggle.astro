---
import Icon from './Icon.astro';
---
<button
  id="theme-toggle"
  type="button"
  class="relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-edge bg-panel text-fg-muted transition-colors hover:border-brand hover:text-brand focus-visible:outline-none"
  aria-label="Toggle color theme"
  title="Toggle light / dark theme"
>
  <Icon name="sun" size={18} class="hidden dark:block" />
  <Icon name="moon" size={18} class="block dark:hidden" />
</button>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const apply = (theme) => {
      document.documentElement.classList.toggle('dark', theme === 'dark');
      try {
        localStorage.setItem('apicircle-site-theme', theme);
      } catch {}
    };
    btn.addEventListener('click', () => {
      const next = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
      apply(next);
    });
    // Keep in sync if the OS preference changes and the user hasn't chosen.
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      let stored = null;
      try {
        stored = localStorage.getItem('apicircle-site-theme');
      } catch {}
      if (!stored) document.documentElement.classList.toggle('dark', e.matches);
    });
  })();
</script>

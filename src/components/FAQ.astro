---
/**
 * Accessible, no-JS FAQ accordion (native <details>). The same items feed the
 * FAQPage structured data in BaseLayout, so the visible copy and the schema
 * always match — a Google rich-result requirement.
 */
import type { Faq } from '../data/faqs.ts';

interface Props {
  items: Faq[];
}
const { items } = Astro.props;
---
<div class="mx-auto max-w-3xl divide-y divide-edge overflow-hidden rounded-2xl border border-edge bg-panel shadow-card">
  {
    items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left text-base font-semibold text-fg transition-colors hover:text-brand [&::-webkit-details-marker]:hidden">
          <span>{item.q}</span>
          <svg
            class="h-5 w-5 shrink-0 text-fg-dim transition-transform duration-200 group-open:rotate-180"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <p class="-mt-1 px-6 pb-5 text-[15px] leading-relaxed text-fg-muted">{item.a}</p>
      </details>
    ))
  }
</div>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout title="Page not found" noindex>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-96 w-[42rem] max-w-full -translate-x-1/2 rounded-full bg-brand/20 blur-[120px]"></div>
      <div class="absolute inset-0 bg-grid opacity-[0.12] mask-fade-b"></div>
    </div>
    <div class="container-page flex min-h-[70vh] flex-col items-center justify-center py-24 text-center">
      <span class="gradient-text text-7xl font-bold tracking-tight sm:text-8xl">404</span>
      <h1 class="mt-4 text-2xl font-bold tracking-tight text-fg sm:text-3xl">This endpoint returned nothing</h1>
      <p class="mt-3 max-w-md text-pretty text-fg-muted">
        The page you’re looking for doesn’t exist or moved. Let’s get you back to a known route.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/" class="btn-primary">
          <Icon name="arrow-right" size={16} class="-scale-x-100" />
          Back home
        </a>
        <a href="/features" class="btn-secondary">Browse features</a>
      </div>
    </div>
  </section>
</BaseLayout>

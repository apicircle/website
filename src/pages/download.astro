---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/site.ts';

const desktop = [
  { os: 'Windows', icon: 'monitor', note: '.exe installer (x64)' },
  { os: 'macOS', icon: 'monitor', note: '.dmg (Apple Silicon & Intel)' },
  { os: 'Linux', icon: 'monitor', note: 'AppImage & .deb' },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Download', url: '/download' },
];
---
<BaseLayout
  title="Download"
  description="Get API Circle Studio — desktop installers for Windows, macOS and Linux, the zero-install web app, the VS Code extension, and the CLI + MCP server on npm."
  breadcrumbs={breadcrumbs}
>
  <Section
    headingLevel="h1"
    eyebrow="Download"
    eyebrowIcon="download"
    title={`Get ${SITE.productName}`}
    subtitle="Five ways to run the same workspace. Start in the browser with zero install, or pick the surface that fits your workflow."
  >
    <!-- Primary: web + desktop -->
    <div class="grid gap-5 lg:grid-cols-2">
      <div class="card flex flex-col">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand/10 text-brand">
          <Icon name="globe" size={22} />
        </span>
        <h3 class="mt-4 text-xl font-semibold text-fg">Web app</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-fg-muted">
          Zero install. Open the browser and your first workspace is created automatically in local storage. The fastest way to try everything.
        </p>
        <a href={SITE.appUrl} target="_blank" rel="noopener" class="btn-primary mt-5 w-full">
          Open studio.apicircle.dev
          <Icon name="arrow-up-right" size={16} />
        </a>
      </div>

      <div class="card flex flex-col">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand/10 text-brand">
          <Icon name="monitor" size={22} />
        </span>
        <h3 class="mt-4 text-xl font-semibold text-fg">Desktop app</h3>
        <p class="mt-2 text-sm leading-relaxed text-fg-muted">
          Day-to-day development with OS-keychain secrets and local mock servers. Windows, macOS, and Linux.
        </p>
        <div class="mt-4 grid grid-cols-3 gap-2">
          {
            desktop.map((d) => (
              <a
                href={SITE.links.releases}
                target="_blank"
                rel="noopener"
                class="flex flex-col items-center gap-1 rounded-xl border border-edge bg-surface/60 px-2 py-3 text-center transition-colors hover:border-brand hover:text-brand"
              >
                <Icon name={d.icon} size={18} />
                <span class="text-sm font-semibold text-fg">{d.os}</span>
                <span class="text-[11px] leading-tight text-fg-dim">{d.note}</span>
              </a>
            ))
          }
        </div>
        <p class="mt-3 text-xs leading-relaxed text-fg-dim">
          Builds are currently unsigned, so the first launch shows a one-time OS prompt.
          <a href={`${SITE.docsBase}/installing.md`} target="_blank" rel="noopener" class="text-brand hover:underline">Installing guide →</a>
        </p>
      </div>
    </div>

    <!-- Secondary: VS Code, CLI, MCP -->
    <div class="mt-5 grid gap-5 lg:grid-cols-3">
      <div class="card flex flex-col">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-node-sky/10 text-node-sky">
          <Icon name="code" size={20} />
        </span>
        <h3 class="mt-4 text-lg font-semibold text-fg">VS Code extension</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-fg-muted">
          Edit the same workspace as YAML, right in your editor.
        </p>
        <div class="mt-4">
          <CodeBlock code="code --install-extension apicircle.apicircle-vscode" prompt lang="Install" />
        </div>
        <div class="mt-3 flex gap-3 text-sm">
          <a href={SITE.links.vscode} target="_blank" rel="noopener" class="text-brand hover:underline">Marketplace</a>
          <a href={SITE.links.openVsx} target="_blank" rel="noopener" class="text-brand hover:underline">Open VSX</a>
        </div>
      </div>

      <div class="card flex flex-col">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-node-blue/10 text-node-blue">
          <Icon name="terminal" size={20} />
        </span>
        <h3 class="mt-4 text-lg font-semibold text-fg">CLI</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-fg-muted">
          Run collections, mocks, and imports in CI. Requires Node ≥ 20.
        </p>
        <div class="mt-4">
          <CodeBlock code="npm install -g @apicircle/cli" prompt lang="Install" />
        </div>
        <a href={SITE.links.npmCli} target="_blank" rel="noopener" class="mt-3 text-sm text-brand hover:underline">View on npm →</a>
      </div>

      <div class="card flex flex-col">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-brand/10 text-brand">
          <Icon name="sparkles" size={20} />
        </span>
        <h3 class="mt-4 text-lg font-semibold text-fg">MCP server</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-fg-muted">
          Let any AI client drive your workspace over the Model Context Protocol.
        </p>
        <div class="mt-4">
          <CodeBlock code="npm install -g @apicircle/mcp-server" prompt lang="Install" />
        </div>
        <a href={SITE.links.npmMcp} target="_blank" rel="noopener" class="mt-3 text-sm text-brand hover:underline">View on npm →</a>
      </div>
    </div>
  </Section>

  <!-- Connect your AI client -->
  <Section
    class="!pt-0"
    eyebrow="Connect your AI client"
    eyebrowIcon="plug"
    title="Wire up AI in four steps"
    subtitle="The desktop and VS Code MCP panels generate a ready-to-paste config for every supported client."
    align="left"
  >
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {
        [
          { n: '1', t: 'Install the binary', b: 'npm install -g @apicircle/mcp-server — or use npx.' },
          { n: '2', t: 'Pick your AI client', b: 'Claude, Cursor, Copilot, ChatGPT, and more.' },
          { n: '3', t: 'Paste the snippet', b: 'Copy the generated config into your client.' },
          { n: '4', t: 'Restart & go', b: 'The client now reads, authors, and runs requests.' },
        ].map((s) => (
          <div class="card">
            <span class="text-sm font-bold text-brand">Step {s.n}</span>
            <h3 class="mt-2 text-base font-semibold text-fg">{s.t}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-fg-muted">{s.b}</p>
          </div>
        ))
      }
    </div>
    <div class="mt-6">
      <a
        href={`${SITE.docsBase}/connect-your-ai-client.md`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:underline"
      >
        Full per-client instructions
        <Icon name="arrow-up-right" size={15} />
      </a>
    </div>
  </Section>
</BaseLayout>
